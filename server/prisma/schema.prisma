generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User Model
model User {
  id                String         @id @default(uuid())
  email             String         @unique
  password          String
  name              String
  isAdmin           Boolean        @default(false)
  isEmailVerified   Boolean        @default(false)
  emailVerifyToken  String?
  resetPasswordToken String?
  resetPasswordExpiry DateTime?
  isSuspended       Boolean        @default(false)
  suspensionReason  String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  // Relations
  subscription      Subscription?
  folders           Folder[]
  files             File[]
  shares            Share[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  
  @@map("users")
}

// Refresh Token Model
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("refresh_tokens")
}

// Package Model
model Package {
  id                Int            @id @default(autoincrement())
  name              String         @unique
  description       String
  maxFolders        Int
  maxNestingLevel   Int
  allowedFileTypes  String[]
  maxFileSize       BigInt
  totalFileLimit    BigInt
  filesPerFolder    Int
  price             Float
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  // Relations
  subscriptions     Subscription[]
  
  @@map("packages")
}

// Subscription Model
model Subscription {
  id          String   @id @default(uuid())
  userId      String   @unique
  packageId   Int
  startDate   DateTime @default(now())
  endDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  package     Package  @relation(fields: [packageId], references: [id])
  
  @@map("subscriptions")
}

// Folder Model
model Folder {
  id          String   @id @default(uuid())
  name        String
  userId      String
  parentId    String?
  path        String
  level       Int      @default(0)
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderHierarchy")
  files       File[]
  
  @@map("folders")
}

// File Model
model File {
  id            String    @id @default(uuid())
  name          String
  originalName  String
  mimeType      String
  size          BigInt
  path          String
  thumbnailPath String?
  userId        String
  folderId      String?
  isFavorite    Boolean   @default(false)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder        Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  versions      FileVersion[]
  
  @@map("files")
}

// File Version Model
model FileVersion {
  id        String   @id @default(uuid())
  fileId    String
  version   Int
  path      String
  size      BigInt
  createdAt DateTime @default(now())
  
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  @@map("file_versions")
}

// Share Model
model Share {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  itemId      String
  itemType    String   // 'file' or 'folder'
  permissions String   // 'view', 'download', 'edit'
  expiresAt   DateTime?
  password    String?
  accessCount Int      @default(0)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("shares")
}

// Notification Model
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // 'info', 'warning', 'error', 'success'
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}
